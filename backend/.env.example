DATABASE_URL=postgresql://localhost:5432/voteapp
REDIS_URL=redis://localhost:6379
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini
AI_TIMEOUT_MS=30000
PROMPT_VERSION=state_resources_v2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OBS_SPIKE_MIN_EVENTS=20
OBS_REJECT_SPIKE_RATE=0.25
OBS_RETRY_SPIKE_RATE=0.25
OBS_FAILED_SPIKE_RATE=0.25
OBS_REASON_SPIKE_COUNT=10
STATE_RESOURCES_SCHEDULER_QUEUE=state_resources_maintenance
STATE_RESOURCES_ANNUAL_CRON="0 3 15 1 *"
STATE_RESOURCES_ANNUAL_TZ=UTC
STATE_RESOURCES_SCHEDULER_MAX_PASSES=3
STATE_RESOURCES_SCHEDULER_BATCH_SIZE=200
STATE_RESOURCES_SCHEDULER_BLOCK_MS=250
